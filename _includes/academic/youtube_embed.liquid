{% comment %}
  Responsive YouTube embed for academic project pages.
  Parameters:
    - include.youtube_id: YouTube video ID (e.g. "JkaxUblCGz0")
{% endcomment %}

{% if include.youtube_id %}
  <div class="academic-video-wrapper">
    <iframe
      src="https://www.youtube.com/embed/{{ include.youtube_id }}"
      frameborder="0"
      allow="autoplay; encrypted-media"
      allowfullscreen
    ></iframe>
  </div>
{% endif %}
