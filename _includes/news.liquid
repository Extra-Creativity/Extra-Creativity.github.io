<div class="news">
  {% assign collection_news = site.news | reverse %}
  {% assign data_news = site.data.news %}
  {% assign has_collection = false %}
  {% assign has_data = false %}
  {% if collection_news.size > 0 %}
    {% assign has_collection = true %}
  {% endif %}
  {% if data_news.size > 0 %}
    {% assign has_data = true %}
  {% endif %}

  {% if has_collection or has_data %}
    {% assign all_news = "" | split: "" %}

    {% for item in collection_news %}
      {% if item.selected %}
        {% assign sel = "true" %}
      {% else %}
        {% assign sel = "false" %}
      {% endif %}
      {% capture entry %}{{ item.date | date: '%Y%m%d%H%M%S' }}||collection||{{ forloop.index0 }}||{{ sel }}{% endcapture %}
      {% assign all_news = all_news | push: entry %}
    {% endfor %}

    {% for item in data_news %}
      {% if item.selected %}
        {% assign sel = "true" %}
      {% else %}
        {% assign sel = "false" %}
      {% endif %}
      {% capture entry %}{{ item.date | date: '%Y%m%d%H%M%S' }}||data||{{ forloop.index0 }}||{{ sel }}{% endcapture %}
      {% assign all_news = all_news | push: entry %}
    {% endfor %}

    {% assign all_news = all_news | sort | reverse %}

    {% assign news_size = all_news.size %}
    {% assign has_selected = false %}
    {% for entry in all_news %}
      {% assign parts = entry | split: "||" %}
      {% if parts[3] == "true" %}
        {% assign has_selected = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% unless include.limit %}
      {% if has_selected %}
        <div class="news-filter mb-3">
          <button id="news-filter-btn" class="btn btn-sm btn-outline-primary" data-filter="all">
            Show selected only
          </button>
        </div>
      {% endif %}
    {% endunless %}

    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% assign news_count = 0 %}
        {% for entry in all_news %}
          {% if news_count >= news_limit %}
            {% break %}
          {% endif %}
          {% assign parts = entry | split: "||" %}
          {% assign source = parts[1] %}
          {% assign idx = parts[2] | plus: 0 %}
          {% assign is_selected = parts[3] %}

          {% if source == "collection" %}
            {% assign item = collection_news[idx] %}
            <tr data-selected="{{ is_selected }}">
              <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
              <td>
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </td>
            </tr>
          {% elsif source == "data" %}
            {% assign item = data_news[idx] %}
            <tr data-selected="{{ is_selected }}">
              <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
              <td>
                {{ item.content | emojify }}
              </td>
            </tr>
          {% endif %}
          {% assign news_count = news_count | plus: 1 %}
        {% endfor %}
      </table>
    </div>

    {% unless include.limit %}
      {% if has_selected %}
        <script>
          document.addEventListener("DOMContentLoaded", function () {
            const btn = document.getElementById("news-filter-btn");
            if (!btn) return;
            const rows = document.querySelectorAll(".news table tr[data-selected]");
            btn.addEventListener("click", function () {
              const current = btn.getAttribute("data-filter");
              if (current === "all") {
                rows.forEach((row) => {
                  row.style.display = row.dataset.selected === "true" ? "" : "none";
                });
                btn.setAttribute("data-filter", "selected");
                btn.textContent = "Show all";
              } else {
                rows.forEach((row) => {
                  row.style.display = "";
                });
                btn.setAttribute("data-filter", "all");
                btn.textContent = "Show selected only";
              }
            });
          });
        </script>
      {% endif %}
    {% endunless %}
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
